# ============================================
# SENTINEL-SQUARE WORKER CONFIGURATION
# ============================================
# Copy this file to .env and fill in your keys
# NEVER commit .env to version control!
# ============================================

# Binance Square API Key (from Creator Center)
BINANCE_SQUARE_API_KEY=your_binance_square_api_key_here

# Google Gemini API Key (from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Schedule Configuration
SLEEP_START_HOUR=2
SLEEP_END_HOUR=7
TIMEZONE=Africa/Nairobi
MIN_INTERVAL_MINUTES=17
MAX_INTERVAL_MINUTES=78
DAILY_POST_TARGET=40

# API Server
API_PORT=8585
API_HOST=0.0.0.0

# Allowed Origins (comma-separated, for CORS)
ALLOWED_ORIGINS=http://localhost:3000,https://sentinel-square.vercel.app
